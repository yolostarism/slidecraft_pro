{
  "version": 2,
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/.*",
      "dest": "/api/index.js"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * data: blob: 'unsafe-inline' 'unsafe-eval'; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline';"
        }
      ]
    }
  ]
}
